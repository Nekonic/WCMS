PORT=3000
HOST=0.0.0.0

# 반드시 변경 (세션 쿠키 서명용)
WCMS_SECRET_KEY=change-this-in-production

# SQLite DB 경로
WCMS_DB_PATH=../db/wcms.sqlite3

# GitHub Actions 버전 업로드 토큰
WCMS_UPDATE_TOKEN=

# 클라이언트 다운로드 base URL (install 스크립트용)
WCMS_SERVER_URL=https://wcms.aps.or.kr

# CORS 허용 오리진 (쉼표 구분, * = 전체 허용)
WCMS_ALLOWED_ORIGINS=*